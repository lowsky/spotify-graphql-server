{
  "name": "spot-graphql-server",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "npm": "12",
    "node": ">=22.x"
  },
  "scripts": {
    "test": "npm run simpletest",
    "simpletest": "node ./test/schemaTest.mjs",
    "printSchema": "node ./bin/printSchema.mjs",
    "watch": "node --watch --env-file=.env serverInit.mjs",
    "start": "node --env-file=.env serverInit.mjs",
    "prepare": "yarn run snyk-protect",
    "snyk-protect": "snyk-protect"
  },
  "dependencies": {
    "@graphql-tools/mock": "9.1.8",
    "@snyk/protect": "1.1305.2",
    "body-parser": "2.3.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "debug": "4.4.3",
    "express": "5.2.1",
    "graphql": "17.0.1",
    "graphql-http": "1.22.4",
    "morgan": "1.11.0",
    "node-fetch": "3.3.2"
  },
  "snyk": true,
  "packageManager": "yarn@4.17.0"
}
